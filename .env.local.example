# Firebase Configuration
# Bu dosyayı .env.local olarak kopyalayın ve kendi değerlerinizi girin

# Firebase Console'dan alacağınız değerler
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Notlar:
# 1. Bu dosyayı .env.local olarak kopyalayın
# 2. Firebase Console'dan config değerlerini alın
# 3. .env.local dosyasını .gitignore'a ekleyin (zaten ekli olmalı)
# 4. NEXT_PUBLIC_ prefix'i client-side'da erişim için gereklidir
